Function main
0: t1 = INT_CONST 1
1: MOV t-1 t1
2: t2 = INT_CONST 2
3: MOV t-2 t2
4: CALL add
5: MOV t3 t-1
6: STR slot(a), d3
7: LOAD d4, slot(a)
8: EXIT d4

Function add
0: MOV t0 t-1
1: STR slot(a), d0
2: MOV t1 t-2
3: STR slot(b), d1
4: LOAD d3, slot(a)
5: LOAD d4, slot(b)
6: ADD d4 d3
7: MOV t-1 t4
8: RETURN

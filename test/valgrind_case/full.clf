  int y;
}

fn main(): int {
  var a = bar(0);
  int b = bar(0);
  v2 x;
  free(x);
  v2 z = { .x = 3, . y = 4 };

  int! constant = 56;

  asm(
    "mov rax, 60",
    "mov rdi, %", z.x
  );

  var d = a + b;

  for (var i = 0; i < a + 10; ++i) {
    if (b == 0) {
      d++;
    }
  }

  while (d > 0) {
    d = d - b + 1;
  }

  if (d == 0) {
    d = 4;
  } else {
